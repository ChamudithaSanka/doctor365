    {
      "name": "05. End Session",
      "item": [
        {
          "name": "✅ End Session with Clinical Notes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();",
                  "pm.test('Status is 200 OK', function() { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Session status is ended', function() { pm.expect(response.data.status).to.equal('ended'); });",
                  "pm.test('ConsultationSummary has durationMinutes', function() {",
                  "  pm.expect(response.data.consultationSummary).to.have.all.keys('startedAt', 'endedAt', 'durationMinutes');",
                  "  pm.expect(response.data.consultationSummary.durationMinutes).to.be.a('number');",
                  "});",
                  "pm.test('Clinical notes stored', function() { pm.expect(response.data.clinicalNotes).to.exist; });",
                  "console.log('✅ Consultation ended. Duration: ' + response.data.consultationSummary.durationMinutes + ' minutes');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{doctor_token}}"}
            ],
            "body": {"mode": "raw", "raw": "{\"notes\": \"Patient presented with acute respiratory symptoms. Prescribed antiviral medication. Follow-up appointment in 3 days.\"}"},
