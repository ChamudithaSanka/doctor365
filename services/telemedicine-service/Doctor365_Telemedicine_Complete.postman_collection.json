                  "  pm.expect(response.data).to.have.all.keys('sessionId', 'appointmentId', 'doctorId', 'patientId', 'meetingProvider', 'meetingRoomId', 'meetingLink', 'status', 'startedAt', 'endedAt', 'duration', 'notes', 'createdAt', 'updatedAt');",
