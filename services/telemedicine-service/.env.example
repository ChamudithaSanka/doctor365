# ===== Database Configuration =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/telemedicine_db?retryWrites=true&w=majority

# ===== Server Configuration =====
PORT=5005
NODE_ENV=development
SERVICE_NAME=telemedicine-service

# ===== JWT Configuration =====
# Must match JWT_SECRET in auth-service and other services
JWT_SECRET=your-secret-key-here

# ===== AGORA Configuration - RTC Token Generation =====
# Get these credentials from: https://console.agora.io/
# Steps:
# 1. Go to Agora Console (https://console.agora.io/)
# 2. Create a new project or select existing project
# 3. In Project Management > Project List, copy the App ID
# 4. In Manage Credentials, generate/copy the App Certificate (Signing Key)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-app-certificate

# ===== Service URLs (for cross-service communication) =====
DOCTOR_SERVICE_URL=http://localhost:5003
PATIENT_SERVICE_URL=http://localhost:5002
APPOINTMENT_SERVICE_URL=http://localhost:5004
