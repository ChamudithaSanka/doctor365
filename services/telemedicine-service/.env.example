# Server Configuration
NODE_ENV=development
PORT=5005
SERVICE_NAME=telemedicine-service

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/doctor365

# JWT Configuration (MUST BE SAME ACROSS ALL SERVICES)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Jitsi Meet Configuration

# Jitsi Mode: 'public' (no JWT) or 'private' (JWT required)
JITSI_MODE=public

# Jitsi Server Domain
# For public Jitsi: meet.jitsi
# For self-hosted: your-jitsi-domain.com
JITSI_DOMAIN=meet.jitsi

# JWT Authentication (Optional - for private/self-hosted Jitsi)
# Set to 'true' only if your Jitsi server requires JWT tokens
JITSI_JWT_ENABLE=false

# Jitsi App ID (required only if JITSI_JWT_ENABLE=true)
JITSI_APP_ID=your-jitsi-app-id

# Jitsi App Secret (required only if JITSI_JWT_ENABLE=true)
JITSI_APP_SECRET=your-jitsi-app-secret
