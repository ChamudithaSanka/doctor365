# ===== Database Configuration =====
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/telemedicine_db?retryWrites=true&w=majority

# ===== Server Configuration =====
PORT=5005
NODE_ENV=development
SERVICE_NAME=telemedicine-service

# ===== JWT Configuration =====
# Must match JWT_SECRET in auth-service and other services
JWT_SECRET=your-secret-key-here

# ===== ZOOM Configuration - OAuth 2.0 Server-to-Server =====
# Get these credentials from: https://developers.zoom.us/
# Steps:
# 1. Go to Zoom App Marketplace (https://marketplace.zoom.us/)
# 2. Create new Server-to-Server OAuth app
# 3. Copy Account ID, Client ID, and Client Secret
# 4. Get Meeting Host User ID from your Zoom account settings
ZOOM_ACCOUNT_ID=your-account-id
ZOOM_CLIENT_ID=your-client-id
ZOOM_CLIENT_SECRET=your-client-secret
ZOOM_MEETING_HOST_ID=your-email@example.com

# ===== Service URLs (for cross-service communication) =====
DOCTOR_SERVICE_URL=http://localhost:5003
PATIENT_SERVICE_URL=http://localhost:5002
APPOINTMENT_SERVICE_URL=http://localhost:5004
