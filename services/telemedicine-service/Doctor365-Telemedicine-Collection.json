    {
      "name": "4. TELEMEDICINE SESSION",
      "item": [
        {
          "name": "4.1 Create Telemedicine Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('session_id', body.data._id);",
                  "    pm.environment.set('zoom_meeting_id', body.data.zoomMeetingId);",
                  "    pm.environment.set('meeting_link', body.data.meetingLink);",
                  "    pm.environment.set('doctor_join_url', body.data.doctorJoinUrl);",
                  "    pm.environment.set('patient_join_url', body.data.patientJoinUrl);",
                  "    console.log('Session created:', body.data._id);",
                  "    console.log('Zoom Meeting ID:', body.data.zoomMeetingId);",
                  "    console.log('Meeting Link:', body.data.meetingLink);",
                  "} else {",
                  "    console.log('Creation failed:', pm.response.code);",
                  "    console.log(pm.response.json());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentId\": \"{{appointment_id}}\"\n}"
            },
            "url": "http://localhost:5005/api/telemedicine/sessions"
          }
        },
        {
          "name": "4.2 Get Session by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": "http://localhost:5005/api/telemedicine/sessions/{{session_id}}"
          }
        },
        {
          "name": "4.3 Start Session (Doctor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    console.log('Session started. Status:', body.data.status);",
                  "} else {",
                  "    console.log('Start failed:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "http://localhost:5005/api/telemedicine/sessions/{{session_id}}/start"
          }
        },
        {
          "name": "4.4 End Session (Doctor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    console.log('Session ended. Status:', body.data.status);",
                  "    console.log('Doctor notes saved');",
                  "} else {",
                  "    console.log('End failed:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorNotes\": \"{{doctor_notes}}\"\n}"
            },
            "url": "http://localhost:5005/api/telemedicine/sessions/{{session_id}}/end"
          }
        },
        {
          "name": "4.5 Add Patient Feedback",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    console.log('Feedback added. Rating:', body.data.patientFeedback.rating);",
                  "} else {",
                  "    console.log('Feedback failed:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"{{feedback_comment}}\"\n}"
            },
            "url": "http://localhost:5005/api/telemedicine/sessions/{{session_id}}/feedback"
          }
        }
      ]
