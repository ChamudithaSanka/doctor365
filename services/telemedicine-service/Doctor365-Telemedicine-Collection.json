    {
      "name": "1. DOCTOR SETUP",
      "item": [
        {
          "name": "1.1 Register Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('doctor_email', body.data.user.email);",
                  "    console.log('Doctor registered:', body.data.user.email);",
                  "} else {",
                  "    console.log('Registration failed:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dr\",\n  \"lastName\": \"{{$randomString}}\",\n  \"email\": \"doctor-{{$timestamp}}@hospital.com\",\n  \"password\": \"SecurePassword123!\",\n  \"role\": \"doctor\"\n}"
            },
            "url": "http://localhost:5001/auth/register"
          }
        },
        {
          "name": "1.2 Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('doctor_token', body.data.token);",
                  "    pm.environment.set('doctor_user_id', body.data.user._id);",
                  "    console.log('Doctor logged in. Token set.');",
                  "} else {",
                  "    console.log('Login failed:', pm.response.code);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctor_email}}\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": "http://localhost:5001/auth/login"
          }
        },
        {
          "name": "1.3 Update Doctor Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('doctor_profile_id', body.data._id);",
                  "    console.log('Doctor profile updated:', body.data._id);",
                  "} else {",
                  "    console.log('Update failed:', pm.response.code);",
                  "    console.log(pm.response.json());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dr\",\n  \"lastName\": \"{{$randomString}}\",\n  \"specialization\": \"{{specialization}}\",\n  \"licenseNumber\": \"LIC-{{$timestamp}}\",\n  \"yearsOfExperience\": 10,\n  \"consultationFee\": 100,\n  \"availabilityStartTime\": \"08:00\",\n  \"availabilityEndTime\": \"18:00\",\n  \"slotMinutes\": 30,\n  \"hospitalOrClinic\": \"{{hospital_name}}\"\n}"
            },
            "url": "http://localhost:5003/api/doctors/me"
          }
        }
      ]
    },
