    {
      "name": "3. APPOINTMENT CREATION",
      "item": [
        {
          "name": "3.1 Create Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('appointment_id', body.data._id);",
                  "    console.log('Appointment created:', body.data._id);",
                  "    console.log('Status:', body.data.status);",
                  "} else {",
                  "    console.log('Creation failed:', pm.response.code);",
                  "    console.log(pm.response.json());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctor_user_id}}\",\n  \"appointmentDate\": \"{{appointment_date}}\",\n  \"appointmentTime\": \"{{appointment_time}}\",\n  \"reason\": \"{{appointment_reason}}\",\n  \"notes\": \"{{appointment_notes}}\"\n}"
            },
            "url": "http://localhost:5004/api/appointments"
          }
        }
      ]
