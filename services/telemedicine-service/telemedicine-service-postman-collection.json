  "item": [
    {
      "name": "0. Generate Test Token (REQUIRED FIRST)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Token generated successfully\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.token).to.exist;",
              "});",
              "",
              "pm.test(\"Token saved to collection variable\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.collectionVariables.set(\"doctor_token\", jsonData.token);",
              "    console.log(\"✅ Doctor token saved:\", jsonData.token.substring(0, 20) + \"...\");",
              "    console.log(\"✅ User:\", jsonData.payload.userId, \"-\", jsonData.payload.email);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"userId\": \"doc-test-001\",\n    \"email\": \"doctor@test.com\",\n    \"role\": \"doctor\",\n    \"name\": \"Dr. Test Doctor\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/generate-token",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "generate-token"
          ]
        }
      },
      "response": []
    },
    {
      "name": "1. Health Check - Jitsi SECURE Mode",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has status ok\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"ok\");",
              "    pm.expect(jsonData.service).to.eql(\"telemedicine-service\");",
              "});",
              "",
              "pm.test(\"Jitsi configuration present\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.jitsi).to.exist;",
              "    pm.expect(jsonData.jitsi.mode).to.eql(\"SECURE\");",
              "});",
              "",
              "pm.test(\"Jitsi SECURE MODE enabled with 8x8.vc\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.jitsi.domain).to.eql(\"8x8.vc\");",
              "    pm.expect(jsonData.jitsi.jwtEnabled).to.be.true;",
              "    pm.expect(jsonData.jitsi.appId).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Telemedicine Session with JWT",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Session created with Jitsi meeting\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property('_id');",
              "    pm.expect(jsonData.data.status).to.eql('scheduled');",
              "    pm.expect(jsonData.data.meetingProvider).to.eql('jitsi');",
              "    pm.collectionVariables.set(\"session_id\", jsonData.data._id);",
              "});",
              "",
              "pm.test(\"Meeting details present in response\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.meetingDetails).to.exist;",
              "    pm.expect(jsonData.meetingDetails.url).to.exist;",
              "    pm.expect(jsonData.meetingDetails.roomId).to.exist;",
              "    pm.expect(jsonData.meetingDetails.jwt).to.exist;",
              "    pm.expect(jsonData.meetingDetails.mode).to.eql('SECURE');",
              "});",
              "",
              "pm.test(\"JWT token is properly formatted\", function () {",
              "    var jsonData = pm.response.json();",
              "    var jwt = jsonData.meetingDetails.jwt;",
              "    // JWT has 3 parts separated by dots",
              "    var parts = jwt.split('.');",
              "    pm.expect(parts.length).to.equal(3);",
              "});",
              "",
              "pm.test(\"Meeting URL contains 8x8.vc domain\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.meetingDetails.url).to.include('8x8.vc');",
              "});",
              "",
              "pm.test(\"Meeting room ID saved in session\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.meetingRoomId).to.equal(jsonData.meetingDetails.roomId);",
              "    pm.expect(jsonData.data.meetingJWT).to.exist;",
              "    pm.collectionVariables.set(\"meeting_room_id\", jsonData.meetingDetails.roomId);",
              "    pm.collectionVariables.set(\"meeting_jwt\", jsonData.meetingDetails.jwt);",
              "    pm.collectionVariables.set(\"meeting_url\", jsonData.meetingDetails.url);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{doctor_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"appointmentId\": \"apt-{{$timestamp}}\",\n    \"patientId\": \"patient-001\",\n    \"meetingProvider\": \"jitsi\"\n}",
