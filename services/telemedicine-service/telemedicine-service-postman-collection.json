  "item": [
    {
      "name": "1. Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has status ok\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"ok\");",
              "    pm.expect(jsonData.service).to.eql(\"telemedicine-service\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/telemedicine/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "telemedicine",
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Telemedicine Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Session created successfully\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property('_id');",
              "    pm.expect(jsonData.data.status).to.eql('scheduled');",
              "    pm.collectionVariables.set(\"session_id\", jsonData.data._id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{doctor_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"appointmentId\": \"apt-001\",\n    \"patientId\": \"patient-001\",\n    \"meetingProvider\": \"jitsi\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/telemedicine/sessions",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "telemedicine",
            "sessions"
          ]
        }
      },
      "response": []
    },
