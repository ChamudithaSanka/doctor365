    {
      "name": "4.5 Verify JWT Token in Session",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Session has meeting JWT token\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data.meetingJWT).to.exist;",
              "    pm.expect(jsonData.data.meetingRoomId).to.exist;",
              "});",
              "",
              "pm.test(\"JWT token is properly formatted (RS256 signature)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var jwt = jsonData.data.meetingJWT;",
              "    // JWT has 3 parts separated by dots",
              "    var parts = jwt.split('.');",
              "    pm.expect(parts.length).to.equal(3);",
              "    // Decode header",
              "    var headerJson = atob(parts[0]);",
              "    var header = JSON.parse(headerJson);",
              "    pm.expect(header.alg).to.equal('RS256');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
