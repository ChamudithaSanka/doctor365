              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"dateOfBirth\": \"1990-05-15\",\n  \"gender\": \"male\",\n  \"phone\": \"+94771234567\",\n  \"address\": \"123 Main St, Colombo\",\n  \"emergencyContact\": \"+94772234567\",\n  \"medicalHistorySummary\": \"No known allergies\"\n}"
            },
            "url": {
              "raw": "http://localhost:5002/api/patients/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
