            },
            "description": "Update your patient profile"
          },
          "response": []
        },
        {
          "name": "Get All Patients (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5002/api/patients",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5002",
              "path": ["api", "patients"]
            },
            "description": "Get all patients (admin only)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "APPOINTMENT SERVICE",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5004/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["health"]
            },
            "description": "Check if appointment service is running"
          },
          "response": []
        },
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctor_id}}\",\n  \"appointmentDate\": \"2026-04-15T10:00:00Z\",\n  \"appointmentTime\": \"10:30\",\n  \"reason\": \"General checkup\",\n  \"notes\": \"First consultation\"\n}"
            },
            "url": {
              "raw": "http://localhost:5004/api/appointments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments"]
            },
            "description": "Create new appointment (patient only). Replace {{doctor_id}} with actual doctor's user ID"
          },
          "response": []
        },
        {
          "name": "Get My Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5004/api/appointments/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "me"]
            },
            "description": "Get your appointments (patient/doctor can see their own)"
          },
          "response": []
        },
        {
          "name": "Get Doctor's Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5004/api/appointments/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "me"]
            },
            "description": "Get appointments assigned to you (doctor view)"
          },
          "response": []
        },
        {
          "name": "Get Appointment by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5004/api/appointments/{{appointment_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "{{appointment_id}}"]
            },
            "description": "Get specific appointment details"
          },
          "response": []
        },
        {
          "name": "Update Appointment Status (Doctor)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "http://localhost:5004/api/appointments/{{appointment_id}}/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "{{appointment_id}}", "status"]
            },
            "description": "Doctor confirms appointment. Status can be: pending, confirmed, cancelled, completed"
          },
          "response": []
        },
        {
          "name": "Update Appointment (Patient)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointmentDate\": \"2026-04-16T10:00:00Z\",\n  \"appointmentTime\": \"11:00\",\n  \"reason\": \"Need urgent consultation\",\n  \"notes\": \"Updated notes\"\n}"
            },
            "url": {
              "raw": "http://localhost:5004/api/appointments/{{appointment_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "{{appointment_id}}"]
            },
            "description": "Update appointment details (patient can only update pending appointments)"
          },
          "response": []
        },
        {
          "name": "Delete Appointment (Patient)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5004/api/appointments/{{appointment_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5004",
              "path": ["api", "appointments", "{{appointment_id}}"]
            },
            "description": "Delete pending appointment (patient only)"
          },
          "response": []
        }
      ]
