{
  "info": {
    "_postman_id": "doctor365-complete-api",
    "name": "Doctor365 Complete API",
    "description": "Complete API collection for Doctor365 microservices - Auth, Patients, Doctors, Appointments",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "AUTH SERVICE",
      "item": [
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@test.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"role\": \"patient\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["auth", "register"]
            },
            "description": "Register a new patient user. Save the returned id as PATIENT_ID and accessToken as PATIENT_TOKEN"
          },
          "response": []
        },
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doctor@test.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Dr. Jane\",\n  \"lastName\": \"Smith\",\n  \"role\": \"doctor\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["auth", "register"]
            },
            "description": "Register a new doctor user. Save the returned id as DOCTOR_ID and accessToken as DOCTOR_TOKEN"
          },
          "response": []
        },
        {
          "name": "Login Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["auth", "login"]
            },
            "description": "Login as patient. Get fresh accessToken"
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:5001/auth/refresh-token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["auth", "refresh-token"]
            },
            "description": "Get new accessToken using refreshToken. Use this when token expires"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{patient_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5001/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5001",
              "path": ["auth", "logout"]
            },
            "description": "Logout (requires valid JWT token)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "DOCTOR SERVICE",
      "item": [
        {
          "name": "Get All Doctors (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5003/api/doctors",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5003",
              "path": ["api", "doctors"]
            },
            "description": "Get list of all doctors (public endpoint, no auth required)"
          },
          "response": []
        },
        {
          "name": "Get Doctor by ID (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5003/api/doctors/{{doctor_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5003",
              "path": ["api", "doctors", "{{doctor_id}}"]
            },
            "description": "Get specific doctor details by ID (public endpoint)"
          },
          "response": []
        },
        {
          "name": "Get My Doctor Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5003/api/doctors/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5003",
              "path": ["api", "doctors", "me"]
            },
            "description": "Get your own doctor profile (requires doctor auth)"
          },
          "response": []
        },
        {
          "name": "Update My Doctor Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{doctor_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Dr. Jane\",\n  \"lastName\": \"Smith\",\n  \"specialization\": \"Cardiology\",\n  \"licenseNumber\": \"LIC123456\",\n  \"yearsOfExperience\": 5,\n  \"consultationFee\": 50,\n  \"availability\": [\"Monday\", \"Tuesday\", \"Wednesday\"],\n  \"hospitalOrClinic\": \"City Hospital\"\n}"
            },
            "url": {
              "raw": "http://localhost:5003/api/doctors/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5003",
              "path": ["api", "doctors", "me"]
            },
            "description": "Update your doctor profile"
          },
          "response": []
        }
      ]
    },
    {
      "name": "PATIENT SERVICE",
